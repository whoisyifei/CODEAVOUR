import js
import time

# --- THE BRIDGE FUNCTION ---
def run_pi(cmd_number):
    url = "http://127.0.0.1:5000/run/" + str(cmd_number)
    js_code = f"fetch('{url}', {{mode: 'no-cors'}})"
    try:
        js.eval(js_code)
        print("Success: Signal sent to Terminal!")
    except:
        pass

