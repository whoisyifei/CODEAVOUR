import serial
import subprocess
import time

# Use the port you found earlier
try:
    ser = serial.Serial('/dev/ttyUSB0', 9600, timeout=0.1)
    # Clear the buffer to start fresh
    ser.reset_input_buffer() 
    print("--- CONNECTED TO /dev/ttyUSB0 ---")
except Exception as e:
    print(f"Error: {e}")
    exit()

while True:
    if ser.in_waiting > 0:
        # Read the raw data to see if anything is coming through
        line = ser.readline().decode('utf-8', errors='replace').strip()
        
        if line:
            print(f"Arduino says: '{line}'") # DEBUG LINE
            
            if "1" in line:
                print(">>> SUCCESS: Starting Clean...")
                subprocess.run("rm -rf static-web", shell=True, cwd="/home/imed/IMEDV4/2025")
            elif "2" in line:
                print(">>> SUCCESS: Starting Build...")
                subprocess.run("cd frontend && npm run build", shell=True, cwd="/home/imed/IMEDV4/2025")
            elif "3" in line:
                print(">>> SUCCESS: Starting All...")
                subprocess.run("npm run start-all", shell=True, cwd="/home/imed/IMEDV4/2025")
