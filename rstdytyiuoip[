import os
import subprocess

# We use 'subprocess' because it is more powerful than 'os.system' 
# for heavy tasks like 'npm run build'

def run_pi_command(cmd):
    try:
        print(f"Executing: {cmd}")
        # This tells the Pi to run the command and show us the output
        process = subprocess.Popen(cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        stdout, stderr = process.communicate()
        if stdout: print(stdout)
        if stderr: print("Error: " + stderr)
    except Exception as e:
        print(f"Failed: {e}")

# STEP 1 & 2: Cleanup
run_pi_command("cd /home/imed/IMEDV4/2025 && rm -rf static-web")

# STEP 3 & 4: Build
run_pi_command("cd /home/imed/IMEDV4/2025/frontend && npm run build")

# STEP 5: Start
run_pi_command("cd /home/imed/IMEDV4/2025 && npm run start-all")
