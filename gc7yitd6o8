import os
import time

# We use the 'print' function to act like Tobi's speech bubbles
# since the 'pictoblox' module is currently missing from your library path.

def trigger_sequence():
    print("Layer 1: Input Received - Starting Sequence...")
    
    # Layer 2: Sending the navigation command to the terminal
    # We use '&&' to keep the terminal inside your folder for the next commands
    cmd_base = "cd /home/imed/IMEDV4/2025 && "
    
    # Layer 3: Executing your specific actions
    os.system(cmd_base + "python3 command1.py")
    time.sleep(0.5)
    os.system(cmd_base + "python3 command2.py")
    time.sleep(0.5)
    os.system(cmd_base + "python3 command3.py")
    time.sleep(0.5)
    os.system(cmd_base + "python3 command4.py")
    print("Sequence Complete!")

def trigger_start():
    print("Layer 1: Input Received - Starting Program...")
    os.system("cd /home/imed/IMEDV4/2025 && python3 start_program.py")

# Since pictoblox.is_key_pressed won't work without the module, 
# use the input() method for your competition testing.
while True:
    choice = input("Enter 'a' for 4-commands or 's' for start: ").lower()
    
    if choice == 'a':
        trigger_sequence()
    elif choice == 's':
        trigger_start()
