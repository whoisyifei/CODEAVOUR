if __name__ == '__main__':
    # 1. Start the AI detection in a separate thread so it doesn't block the API
    camera_thread = threading.Thread(target=ai_camera_loop, daemon=True)
    camera_thread.start()

    print(f"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}][SERVER] Flask API + AI Camera starting...")
    
    try:
        app.run(host='0.0.0.0', port=5000, debug=False, use_reloader=False)
    except Exception as e:
        print(f"[CRITICAL] {e}", file=sys.stderr)
