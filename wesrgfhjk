from flask import Flask, jsonify, request, send_from_directory
from flask_cors import CORS
import status_state 
import shared_state 
from datetime import datetime
import os
import sys
import subprocess

# --- CONFIGURATION ---
STATIC_FOLDER = 'static_web'
# This path is where your terminal commands will run
BASE_PATH = "/home/imed/IMEDV4/2025"

app = Flask(__name__, static_folder=STATIC_FOLDER, static_url_path='')
CORS(app) 

# === MERGED BRIDGE COMMANDS (For PictoBlox / AI) ===

@app.route('/run/<command_id>')
def execute_command(command_id):
    """Bridge logic for PictoBlox AI to trigger system commands"""
    try:
        if command_id == "1":
            print(">>> [AI] Command Received: CLEAN")
            # We use 'static_web' to match your Flask config
            subprocess.run("rm -rf static_web", shell=True, cwd=BASE_PATH)
            return "Cleaned!", 200
        
        elif command_id == "2":
            print(">>> [AI] Command Received: BUILD")
            # Build the project, then we rename the output folder to match STATIC_FOLDER
            build_cmd = "cd frontend && npm run build && rm -rf ../static_web && mv dist ../static_web"
            subprocess.run(build_cmd, shell=True, cwd=BASE_PATH)
            return "Built and Deployed!", 200

        elif command_id == "3":
            print(">>> [AI] Command Received: START")
            subprocess.run("npm run start-all", shell=True, cwd=BASE_PATH)
            return "Started!", 200

        return "Unknown Command", 400
    except Exception as e:
        return f"Error: {str(e)}", 500

# === EXISTING LOG API ROUTES ===

@app.route('/api/status', methods=['GET'])
def get_system_status():
    return jsonify(status_state.CURRENT_STATUS)

@app.route('/api/log', methods=['POST'])
def receive_log():
    if not request.is_json:
        return jsonify({"message": "Missing JSON"}), 400
    log_entry = request.get_json()
    try:
        shared_state.LOG_ENTRIES.appendleft(log_entry)
        print(f"[LOG][{log_entry['component']}] {log_entry['message']}")
    except:
        pass
    return jsonify({"status": "Log received"}), 200

@app.route('/api/logs', methods=['GET'])
def get_logs():
    try:
        return jsonify(list(shared_state.LOG_ENTRIES))
    except:
        return jsonify([]), 200

# === FRONTEND SERVING ROUTE ===

@app.route('/', defaults={'path': ''})
@app.route('/<path:path>')
def serve_react_app(path):
    full_path = os.path.join(STATIC_FOLDER, path)
    if path != "" and os.path.exists(full_path):
        return send_from_directory(STATIC_FOLDER, path)
    
    index_path = os.path.join(STATIC_FOLDER, 'index.html')
    if not os.path.exists(index_path):
        return "Frontend not found. Run Command 2 from PictoBlox first!", 404
        
    return send_from_directory(STATIC_FOLDER, 'index.html')

if __name__ == '__main__':
    print(f"[{datetime.now()}] SERVER STARTING ON http://0.0.0.0:5000")
    # Setting use_reloader=False is important so it doesn't conflict with subprocesses
    app.run(host='0.0.0.0', port=5000, debug=False, use_reloader=False)
