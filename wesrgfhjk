@app.route('/run/<command_id>')
def execute_command(command_id):
    """
    Bridge logic for PictoBlox AI to trigger system commands.
    This allows the AI to control the underlying Linux system.
    """
    try:
        if command_id == "1":
            print(f"[{datetime.now().strftime('%H:%M:%S')}][AI_TRIGGER] Command: CLEAN")
            # Deletes the old web folder to prepare for a fresh build
            subprocess.run("rm -rf static_web", shell=True, cwd=BASE_PATH)
            return jsonify({"status": "Cleaned static_web folder"}), 200
        
        elif command_id == "2":
            print(f"[{datetime.now().strftime('%H:%M:%S')}][AI_TRIGGER] Command: BUILD")
            # 1. Build the React project
            # 2. Remove any existing static_web
            # 3. Rename the 'dist' output to 'static_web' so Flask can serve it
            build_chain = "cd frontend && npm run build && rm -rf ../static_web && mv dist ../static_web"
            subprocess.run(build_chain, shell=True, cwd=BASE_PATH)
            return jsonify({"status": "Project Built and Deployed to static_web"}), 200

        elif command_id == "3":
            print(f"[{datetime.now().strftime('%H:%M:%S')}][AI_TRIGGER] Command: START")
            # Runs your custom start-all script
            subprocess.run("npm run start-all", shell=True, cwd=BASE_PATH)
            return jsonify({"status": "Start-all sequence initiated"}), 200

        return jsonify({"error": "Unknown Command ID"}), 400
    except Exception as e:
        print(f"[ERROR][BRIDGE] {e}")
        return jsonify({"error": str(e)}), 500

